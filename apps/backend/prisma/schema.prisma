// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- CORE MULTI-TENANCY ---

model Company {
  id                 String           @id @default(uuid())
  name               String           @unique
  registrationNumber String           @unique
  sector             String?
  currency           String?
  fiscalYearStart    Int?
  country            String?
  // --- Branding (Report PDF customization) ---
  logoUrl            String?
  primaryColor       String?          @default("#1E3A5F")
  secondaryColor     String?          @default("#2563EB")
  users              User[]           // Represents users whose active company is this one
  members            UserCompany[]    // Represents all members of this company (multi-company relation)
  batches            ImportBatch[]
  predictions        Prediction[]
  valuations         SavedValuation[]
  reports            Report[]
  superAdminId       String?
  superAdmin         SuperAdmin?      @relation("SuperAdminCompanies", fields: [superAdminId], references: [id])
  createdAt          DateTime         @default(now())
  deletedAt          DateTime?
}

model User {
  id           String    @id @default(uuid())
  firstName    String
  lastName     String
  email        String    @unique
  password     String
  refreshToken String?
  role         UserRole  @default(COLLAB)
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  memberships  UserCompany[] // Multi-company memberships
  reports      Report[]
  createdAt            DateTime        @default(now())
  deletedAt            DateTime?
  superAdmin           SuperAdmin?
  preference           UserPreference?

  isEmailVerified      Boolean         @default(false)
  verifyEmailToken     String?         @unique
  resetPasswordToken   String?         @unique
  resetPasswordExpires DateTime?
  inviteToken          String?         @unique
  inviteTokenExpires   DateTime?
}

model UserCompany {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId String
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      UserRole @default(COLLAB)
  password  String   // Hashed password specific to this company membership
  createdAt DateTime @default(now())

  @@unique([userId, companyId])
}

enum UserRole {
  OWNER
  ADMIN
  COLLAB
  READER
  USER
}

// --- DATA & AI PIPELINE ---

model ImportBatch {
  id            String          @id @default(uuid())
  companyId     String
  company       Company         @relation(fields: [companyId], references: [id])
  data          FinancialData[]
  createdAt     DateTime        @default(now())
  // --- Sheet 3: Strategic KPIs ---
  cac           Float?
  ltv           Float?
  tam           Float?
  marketShare   Float?
  employeeCount Int?
  // --- Sheet 1: Annual Valuation Data ---
  macroFeatures Json?
}

model FinancialData {
  id      String      @id @default(uuid())
  batchId String
  batch   ImportBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  metric  String
  value   Float
  period  DateTime

  @@index([batchId, metric, period])
}

model Prediction {
  id        String           @id @default(uuid())
  companyId String
  company   Company          @relation(fields: [companyId], references: [id])
  status    PredictionStatus @default(PENDING)
  result    Json?
  createdAt DateTime         @default(now())
}

enum PredictionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// --- VALUATION HISTORY ---

model SavedValuation {
  id              String   @id @default(uuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  userId          String
  method          String
  inputs          Json
  enterpriseValue Float?
  equityValue     Float
  formula         String
  explanation     String
  label           String?
  createdAt       DateTime @default(now())

  @@index([companyId, createdAt(sort: Desc)])
}

// --- NOTIFICATIONS ---

model Notification {
  id        String             @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean            @default(false)
  link      String?
  createdAt DateTime           @default(now())

  @@index([userId, read, createdAt(sort: Desc)])
}

enum NotificationType {
  IMPORT_SUCCESS
  VALUATION_COMPLETE
  PREDICTION_READY
  ANOMALY_DETECTED
  TEAM_INVITE
  SYSTEM_ALERT
}

// --- REPORT GENERATION ---

model Report {
  id             String       @id @default(uuid())
  companyId       String
  company         Company      @relation(fields: [companyId], references: [id])
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  status          ReportStatus @default(QUEUED)
  language        String       @default("FR")
  lengthProfile   String       @default("MEDIUM")
  reportTypes     String[]
  problemStatement String?
  batchId         String?
  snapshot        Json?
  content         Json?
  artifactPath    String?
  pageCount       Int?
  error           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  generatedAt     DateTime?

  @@index([companyId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

enum ReportStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

// --- LANDING PAGE INVITATIONS ---

model InvitationRequest {
  id          String                  @id @default(uuid())
  fullName    String
  email       String                  @unique
  companyName String?
  role        String?
  message     String?
  status      InvitationRequestStatus @default(PENDING)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt

  @@index([status, createdAt(sort: Desc)])
}

enum InvitationRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model SuperAdmin {
  id         String    @id @default(uuid())
  userId     String    @unique
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  promotedAt DateTime  @default(now())
  promotedBy String    @default("System")
  
  // 1 SuperAdmin gère 1..* Company
  companies  Company[] @relation("SuperAdminCompanies")
}

model UserPreference {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme     String   @default("light")
  language  String   @default("fr")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
