FROM node:20-alpine

# Install curl for font download
RUN apk add --no-cache curl

WORKDIR /usr/src/app

# Download Arabic font (Noto Sans Arabic for PDFKit)
RUN mkdir -p /usr/src/app/fonts && \
    curl -L -o /usr/src/app/fonts/NotoSansArabic-Regular.ttf \
    "https://github.com/google/fonts/raw/main/ofl/notosansarabic/NotoSansArabic%5Bwdth%2Cwght%5D.ttf" && \
    curl -L -o /usr/src/app/fonts/NotoSansArabic-Bold.ttf \
    "https://github.com/google/fonts/raw/main/ofl/notosansarabic/NotoSansArabic%5Bwdth%2Cwght%5D.ttf"

# Install dependencies first (better caching)
COPY package*.json ./

RUN npm install

# Copy Prisma schema and generate client
COPY prisma ./prisma/
RUN npx prisma generate

# Copy rest of the application
COPY . .

# Expose NestJS port
EXPOSE 3000

# Start NestJS in development mode with hot-reload
CMD ["npm", "run", "start:dev"]